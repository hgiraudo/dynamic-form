    {
      "title": "FATCA / OCDE",
      "description": "FATCA / OCDE",
      "icon": "cilGlobeAlt",
      "fields": [
        {
          "type": "comment",
          "name": "RF_Intro",
          "content": "A los efectos del intercambio de información de cuentas financieras establecido por la Organización para la Cooperación y el Desarrollo Económico (OCDE) y la Resolución General Nº 4056/2017 de la AFIP y sus modificatorias, y en cumplimiento de la Ley Foreign Account Tax Compliance Act (FATCA) de los Estados Unidos (EEUU), el Cliente declara tener residencia fiscal en el (los) país(es) detallado(s) a continuación:",
          "hideOnRevision": true
        },
        {
          "type": "subtitle",
          "name": "RF1_Title",
          "content": "Residencia Fiscal",
          "hideOnRevision": true
        },
