{
  "title": "Perfil de Riesgo",
  "templatePdf": "perfil-de-riesgo.pdf",
  "derivedFields": [
    { "source": "TramiteFecha",      "name": "PerfilRiesgoDia",             "value": "val.split(\"/\")[0]" },
    { "source": "TramiteFecha",      "name": "PerfilRiesgoMes",             "value": "val.split(\"/\")[1]" },
    { "source": "TramiteFecha",      "name": "PerfilRiesgoAno",             "value": "val.split(\"/\")[2]" },
    { "source": "NumeroDeComitente", "name": "PerfilRiesgoNumeroComitente", "value": "val" },
    { "source": "PerfilRiesgo",      "name": "PerfilRiesgoBajo",            "value": "val === 'RB - Bajo'  ? '/' : ''" },
    { "source": "PerfilRiesgo",      "name": "PerfilRiesgoMedio",           "value": "val === 'RM - Medio' ? '/' : ''" },
    { "source": "PerfilRiesgo",      "name": "PerfilRiesgoAlto",            "value": "val === 'RA - Alto'  ? '/' : ''" }
  ],
  "globalDerivedFields": [
    { "name": "PerfilRiesgoAclaracion", "value": "{Firmante1Nombre} {Firmante1Apellido}" }
  ]
}
