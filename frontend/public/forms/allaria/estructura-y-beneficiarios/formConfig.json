{
  "steps": [
    {
      "title": "Firmantes",
      "description": "Firmantes",
      "icon": "cilPeople",
      "fields": [
        {
          "name": "NumeroFirmantes",
          "label": "Cantidad de firmantes",
          "type": "button-group",
          "options": ["1", "2"],
          "default": "1"
        },
        {
          "name": "RazonSocial",
          "label": "Razón Social",
          "type": "text",
          "placeholder": "ej. Arroyito S.A."
        },
        {
          "name": "NumeroDeComitente",
          "label": "Número de Comitente",
          "type": "text",
          "placeholder": "ej. 123,456",
          "formatter": "thousandsFormatter"
        },
        {
          "name": "TramiteFecha",
          "label": "Fecha",
          "type": "date",
          "default": "today"
        },
        {
          "type": "spacer",
          "name": "spacer_F1"
        },
        {
          "type": "subtitle",
          "name": "F1_Title",
          "content": "Firmante 1"
        },
        {
          "name": "Firmante1Nombre",
          "label": "Nombre",
          "type": "text",
          "example": "Juan Carlos"
        },
        {
          "name": "Firmante1Apellido",
          "label": "Apellido",
          "type": "text",
          "example": "García"
        },
        {
          "name": "Firmante1Email",
          "label": "Correo",
          "type": "email",
          "example": "jgarcia@empresa.com.ar"
        },
        {
          "name": "CertificadoRep1",
          "label": "Utiliza un certificado personal (Ley 27446)",
          "type": "checkbox"
        },
        {
          "name": "SmsRep1",
          "label": "Enviar código de autorización por SMS",
          "type": "checkbox"
        },
        {
          "name": "RepresentanteTelefono1",
          "label": "Número de celular",
          "type": "tel",
          "visibleIf": { "field": "SmsRep1", "value": true },
          "placeholder": "ej. +54 9 11 1234-5678"
        },
        {
          "type": "spacer",
          "name": "spacer_F2",
          "visibleIf": { "field": "NumeroFirmantes", "value": "2" }
        },
        {
          "type": "subtitle",
          "name": "F2_Title",
          "content": "Firmante 2",
          "visibleIf": { "field": "NumeroFirmantes", "value": "2" }
        },
        {
          "name": "Firmante2Nombre",
          "label": "Nombre",
          "type": "text",
          "example": "María Isabel",
          "visibleIf": { "field": "NumeroFirmantes", "value": "2" }
        },
        {
          "name": "Firmante2Apellido",
          "label": "Apellido",
          "type": "text",
          "example": "López",
          "visibleIf": { "field": "NumeroFirmantes", "value": "2" }
        },
        {
          "name": "Firmante2Email",
          "label": "Correo",
          "type": "email",
          "example": "mlopez@empresa.com.ar",
          "visibleIf": { "field": "NumeroFirmantes", "value": "2" }
        },
        {
          "name": "CertificadoRep2",
          "label": "Utiliza un certificado personal (Ley 27446)",
          "type": "checkbox",
          "visibleIf": { "field": "NumeroFirmantes", "value": "2" }
        },
        {
          "name": "SmsRep2",
